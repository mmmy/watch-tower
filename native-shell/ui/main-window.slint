import { HorizontalBox, ListView, VerticalBox } from "std-widgets.slint";

export struct SignalRowData {
    title: string,
    meta: string,
    is_header: bool,
    unread: bool,
    pending: bool,
    unread_count: int,
    timeline_visible: bool,
    timeline_ratio: float,
    timeline_positive: bool,
}

component PlainButton inherits Rectangle {
    in property <string> text;
    callback clicked();

    min-width: 34px;
    height: 22px;
    border-width: 1px;
    border-color: #b8b8b8;
    background: #f6f6f6;

    TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        x: 8px;
        y: 4px;
        width: parent.width - 16px;
        text: root.text;
        color: #202020;
        font-size: 11px;
        horizontal-alignment: center;
        overflow: elide;
    }
}

component MoreButton inherits Rectangle {
    in property <string> text;
    callback clicked();

    width: 24px;
    height: 18px;
    border-width: 1px;
    border-color: #b8b8b8;
    background: #f6f6f6;

    TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        y: 2px;
        width: parent.width;
        text: root.text;
        color: #202020;
        font-size: 9px;
        horizontal-alignment: center;
        overflow: elide;
    }
}

component MenuButton inherits Rectangle {
    in property <string> text;
    callback clicked();

    width: 100%;
    height: 28px;
    border-width: 1px;
    border-color: #c3c3c3;
    background: #f7f7f7;

    TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        y: 5px;
        width: parent.width;
        text: root.text;
        color: #202020;
        font-size: 12px;
        horizontal-alignment: center;
        overflow: elide;
    }
}

component PlainCheckBox inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled();

    min-width: 44px;
    height: 18px;
    background: transparent;

    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }

    Rectangle {
        x: 0px;
        y: 3px;
        width: 11px;
        height: 11px;
        border-width: 1px;
        border-color: #7a7a7a;
        background: root.checked ? #dcdcdc : #ffffff;

        if root.checked : Text {
            x: 1px;
            y: -3px;
            width: parent.width;
            text: "√";
            color: #202020;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 15px;
        y: 1px;
        width: parent.width - 15px;
        text: root.text;
        color: #202020;
        font-size: 11px;
        overflow: elide;
    }
}

export component MainWindow inherits Window {
    title: "Signal Desk Native";
    preferred-width: 420px;
    preferred-height: 900px;
    min-width: 40px;
    min-height: 100px;
    background: #f3f3f3;

    in-out property <int> unread-count: 0;
    in-out property <string> status-text: "Ready";
    in-out property <string> refresh-label: "No refresh action yet";
    in-out property <string> runtime-summary: "Runtime not connected";
    in-out property <string> save-hint: "No save activity yet";
    in-out property <string> connection-label: "Unknown";
    in-out property <string> connection-tone: "offline";
    in-out property <string> stats-primary: "0 enabled group(s)";
    in-out property <string> stats-secondary: "0 section(s)";
    in-out property <string> stats-tertiary: "Tick 0 @ 0s poll";
    in-out property <string> stats-quaternary: "Updated n/a";
    in-out property <string> edge-width-label: "120 px";
    in-out property <[SignalRowData]> signal-rows: [];
    in-out property <bool> main-visible: true;
    in-out property <bool> widget-visible: true;
    in-out property <bool> pin-enabled: true;
    in-out property <bool> edge-mode: false;
    in-out property <bool> notifications-enabled: true;
    in-out property <bool> sound-enabled: true;
    callback toggle-always-on-top();
    callback toggle-edge-mode();
    callback adjust-edge-width(int);
    callback toggle-notifications();
    callback toggle-sound();
    callback toggle-widget();
    callback refresh-data();
    callback hide-main();
    callback save-config();
    callback quit-app();
    callback toggle-signal-read(int);

    VerticalBox {
        padding: 2px;
        spacing: 2px;

        toolbar := Rectangle {
            height: 30px;
            border-width: 1px;
            border-color: #c8c8c8;
            background: #efefef;

            PlainCheckBox {
                x: 6px;
                y: 5px;
                width: 40px;
                text: "置顶";
                checked <=> root.pin-enabled;
                toggled => {
                    root.toggle-always-on-top();
                }
            }

            PlainCheckBox {
                x: 52px;
                y: 5px;
                width: 72px;
                text: "贴边模式";
                checked <=> root.edge-mode;
                toggled => {
                    root.toggle-edge-mode();
                }
            }

            PlainCheckBox {
                x: 130px;
                y: 5px;
                width: 40px;
                text: "通知";
                checked <=> root.notifications-enabled;
                toggled => {
                    root.toggle-notifications();
                }
            }

            PlainCheckBox {
                x: 176px;
                y: 5px;
                width: 40px;
                text: "声音";
                checked <=> root.sound-enabled;
                toggled => {
                    root.toggle-sound();
                }
            }

            MoreButton {
                x: parent.width - self.width - 6px;
                y: 5px;
                text: "更多";
                clicked => {
                    more-menu.show();
                }
            }

            more-menu := PopupWindow {
                x: toolbar.width - self.width - 6px;
                y: toolbar.height - 1px;
                width: 170px;
                height: 152px;
                close-policy: close-on-click-outside;

                Rectangle {
                    border-width: 1px;
                    border-color: #bdbdbd;
                    background: #f3f3f3;

                    VerticalLayout {
                        padding: 6px;
                        spacing: 6px;

                        MenuButton {
                            text: "立即轮询";
                            clicked => {
                                more-menu.close();
                                root.refresh-data();
                            }
                        }

                        Rectangle {
                            height: 28px;
                            border-width: 1px;
                            border-color: #d0d0d0;
                            background: #ffffff;

                            Text {
                                x: 8px;
                                y: 6px;
                                width: parent.width - 48px;
                                text: root.edge-width-label;
                                color: #202020;
                                font-size: 12px;
                                overflow: elide;
                            }

                            PlainButton {
                                x: parent.width - 42px;
                                y: 3px;
                                width: 16px;
                                text: "-";
                                clicked => {
                                    root.adjust-edge-width(-20);
                                }
                            }

                            PlainButton {
                                x: parent.width - 22px;
                                y: 3px;
                                width: 16px;
                                text: "+";
                                clicked => {
                                    root.adjust-edge-width(20);
                                }
                            }
                        }

                        MenuButton {
                            text: "保存配置";
                            clicked => {
                                more-menu.close();
                                root.save-config();
                            }
                        }

                        MenuButton {
                            text: "隐藏";
                            clicked => {
                                more-menu.close();
                                root.hide-main();
                            }
                        }

                        MenuButton {
                            text: "退出";
                            clicked => {
                                more-menu.close();
                                root.quit-app();
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 28px;
            border-width: 1px;
            border-color: #c8c8c8;
            background: #f8f8f8;

            Rectangle {
                x: 6px;
                y: 4px;
                width: 42px;
                height: 18px;
                border-width: root.unread-count > 0 ? 1px : 0px;
                border-color: #d3a000;
                background: root.unread-count > 0 ? #ffd24d : #f8f8f8;

                Text {
                    y: 3px;
                    width: parent.width;
                    text: root.unread-count;
                    color: #202020;
                    font-size: 12px;
                    font-weight: root.unread-count > 0 ? 600 : 400;
                    horizontal-alignment: center;
                }
            }

            time-prefix := Text {
                x: 54px;
                y: 6px;
                text: root.stats-quaternary + " | ";
                color: #404040;
                font-size: 12px;
            }

            connection-status := Text {
                x: time-prefix.x + time-prefix.width;
                y: 6px;
                text: root.connection-label;
                color: root.connection-tone == "offline" ? #c62828 : #404040;
                font-size: 12px;
            }

            Text {
                x: connection-status.x + connection-status.width;
                y: 6px;
                width: parent.width - self.x - 6px;
                text: " | " + root.status-text;
                color: #404040;
                font-size: 12px;
                overflow: elide;
            }
        }

        Rectangle {
            border-width: 1px;
            border-color: #c8c8c8;
            background: #ffffff;

            VerticalLayout {
                padding-left: 2px;
                padding-right: 2px;
                padding-top: 2px;
                padding-bottom: 2px;
                spacing: 2px;

                Rectangle {
                    height: 24px;
                    background: #f0f0f0;
                    border-width: 1px;
                    border-color: #d8d8d8;

                    Text {
                        x: 6px;
                        y: 5px;
                        width: parent.width - 12px;
                        text: "分组  " + root.stats-primary + "  " + root.stats-secondary + "  " + root.stats-tertiary;
                        color: #404040;
                        font-size: 12px;
                        overflow: elide;
                    }
                }

                ListView {
                    height: 610px;

                    for signal-row[index] in root.signal-rows : Rectangle {
                        height: signal-row.is_header ? 40px : 22px;
                        background: signal-row.is_header ? #f7f7f7 : #ffffff;
                        border-width: 0px;
                        border-color: #e0e0e0;

                        TouchArea {
                            clicked => {}
                        }

                        left-hit-area := Rectangle {
                            x: 0px;
                            y: 0px;
                            width: signal-row.is_header ? 0px : 40px;
                            height: parent.height;
                            background: left-hit-touch.has-hover ? #f3f3f3 : transparent;
                            visible: !signal-row.is_header;

                            left-hit-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.toggle-signal-read(index);
                                }
                            }
                        }

                        Rectangle {
                            x: 2px;
                            y: 10px;
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            visible: !signal-row.is_header && (signal-row.pending || signal-row.unread);
                            background: signal-row.pending ? #ef4444
                                : signal-row.unread ? #f0b100
                                : #9ca3af;
                        }

                        Text {
                            x: signal-row.is_header ? 6px : 8px;
                            y: signal-row.is_header ? 4px : 4px;
                            width: signal-row.is_header ? 64px : 32px;
                            text: signal-row.title;
                            color: signal-row.is_header ? #202020
                                : signal-row.unread ? #d99500
                                : #202020;
                            font-size: signal-row.is_header ? 15px : 12px;
                            font-weight: signal-row.is_header ? 600 : (signal-row.unread ? 600 : 400);
                            overflow: elide;
                        }

                        Rectangle {
                            x: 90px;
                            y: 6px;
                            width: signal-row.pending ? 24px : (signal-row.unread_count > 9 ? 24px : 18px);
                            height: 16px;
                            visible: signal-row.is_header && (signal-row.pending || signal-row.unread_count > 0);
                            border-width: 1px;
                            border-color: #d3a000;
                            background: #ffd24d;

                            Text {
                                y: 2px;
                                width: parent.width;
                                text: signal-row.pending ? "..." : signal-row.unread_count;
                                color: #202020;
                                font-size: 10px;
                                font-weight: 600;
                                horizontal-alignment: center;
                            }
                        }

                        Text {
                            x: signal-row.is_header ? 6px : 58px;
                            y: signal-row.is_header ? 22px : 4px;
                            width: signal-row.is_header ? parent.width - 86px : 0px;
                            text: signal-row.meta;
                            color: signal-row.unread ? #404040 : #707070;
                            font-size: signal-row.is_header ? 11px : 10px;
                            overflow: elide;
                            visible: signal-row.is_header;
                        }

                        Rectangle {
                            x: signal-row.is_header ? parent.width - 92px : 40px;
                            y: signal-row.is_header ? 10px : 4px;
                            width: signal-row.is_header ? 74px : parent.width - 50px;
                            height: 18px;
                            background: signal-row.is_header ? transparent : #edf0f4;
                            visible: !signal-row.is_header && signal-row.timeline_visible;

                            Rectangle {
                                x: signal-row.timeline_ratio * (parent.width - self.width);
                                y: 0px;
                                width: 4px;
                                height: parent.height;
                                background: signal-row.timeline_positive ? #34d399 : #ef4444;
                            }
                        }
                    }
                }
            }
        }
    }
}

export component WidgetWindow inherits Window {
    title: "Signal Desk Widget";
    preferred-width: 50px;
    preferred-height: 50px;
    min-width: 50px;
    min-height: 50px;
    max-width: 50px;
    max-height: 50px;
    always-on-top: true;
    no-frame: true;
    background: transparent;

    in-out property <int> unread-count: 0;
    in-out property <bool> last-refresh-failed: false;
    in-out property <string> status-text: "Ready";
    in-out property <bool> widget-visible: true;
    in-out property <bool> drag-primed: false;
    in-out property <bool> drag-started: false;

    callback open-main();
    callback refresh-data();
    callback start-widget-drag();
    callback show-widget-menu();
    callback hover-started();
    callback hover-ended();

    TouchArea {
        mouse-cursor: grab;

        changed has-hover => {
            if self.has-hover {
                root.hover-started();
            } else {
                root.hover-ended();
            }
        }

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                root.drag-primed = true;
                root.drag-started = false;
            } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                root.drag-primed = false;
            } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                root.drag-primed = false;
                root.drag-started = false;
                root.show-widget-menu();
            } else if (event.kind == PointerEventKind.cancel) {
                root.drag-primed = false;
                root.drag-started = false;
            }
        }

        moved => {
            if (root.drag-primed && !root.drag-started &&
                    (Math.abs(self.mouse_x - self.pressed_x) > 3px ||
                    Math.abs(self.mouse_y - self.pressed_y) > 3px)) {
                root.drag-started = true;
                root.start-widget-drag();
            }
        }

        clicked => {
            if (!root.drag-started) {
                root.open-main();
            }
            root.drag-primed = false;
            root.drag-started = false;
        }

        double-clicked => {
            if (!root.drag-started) {
                root.refresh-data();
            }
            root.drag-primed = false;
            root.drag-started = false;
        }
    }

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 25px;
        background: root.last-refresh-failed
            ? (root.widget-visible ? #dc2626 : #7f1d1d)
            : root.unread-count > 0
            ? (root.widget-visible ? #d97706 : #78350f)
            : (root.widget-visible ? #2563eb : #475569);

        Text {
            width: parent.width;
            height: parent.height;
            visible: !root.last-refresh-failed || root.unread-count > 0;
            text: root.unread-count;
            color: #eff6ff;
            font-size: root.unread-count > 9 ? 17px : 18px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            width: parent.width;
            height: parent.height;
            visible: root.last-refresh-failed && root.unread-count == 0;
            text: "!";
            color: #fffbeb;
            font-size: 22px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Rectangle {
            x: parent.width - self.width - 4px;
            y: 4px;
            width: 14px;
            height: 14px;
            visible: root.last-refresh-failed && root.unread-count > 0;
            border-radius: 7px;
            background: #fffbeb;

            Text {
                width: parent.width;
                height: parent.height;
                text: "!";
                color: #9a3412;
                font-size: 10px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
