import { HorizontalBox, ListView, VerticalBox } from "std-widgets.slint";

export struct SignalRowData {
    title: string,
    meta: string,
    is_header: bool,
    unread: bool,
    pending: bool,
    unread_count: int,
}

component PlainButton inherits Rectangle {
    in property <string> text;
    callback clicked();

    min-width: 34px;
    height: 22px;
    border-width: 1px;
    border-color: #b8b8b8;
    background: #f6f6f6;

    TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        x: 8px;
        y: 4px;
        width: parent.width - 16px;
        text: root.text;
        color: #202020;
        font-size: 11px;
        horizontal-alignment: center;
        overflow: elide;
    }
}

component MoreButton inherits Rectangle {
    in property <string> text;
    callback clicked();

    width: 24px;
    height: 18px;
    border-width: 1px;
    border-color: #b8b8b8;
    background: #f6f6f6;

    TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        y: 2px;
        width: parent.width;
        text: root.text;
        color: #202020;
        font-size: 9px;
        horizontal-alignment: center;
        overflow: elide;
    }
}

component PlainCheckBox inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled();

    min-width: 44px;
    height: 18px;
    background: transparent;

    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }

    Rectangle {
        x: 0px;
        y: 3px;
        width: 11px;
        height: 11px;
        border-width: 1px;
        border-color: #7a7a7a;
        background: root.checked ? #dcdcdc : #ffffff;

        if root.checked : Text {
            x: 1px;
            y: -3px;
            width: parent.width;
            text: "√";
            color: #202020;
            font-size: 10px;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 15px;
        y: 1px;
        width: parent.width - 15px;
        text: root.text;
        color: #202020;
        font-size: 11px;
        overflow: elide;
    }
}

export component MainWindow inherits Window {
    title: "Signal Desk Native";
    preferred-width: 420px;
    preferred-height: 700px;
    min-width: 340px;
    min-height: 500px;
    background: #f3f3f3;

    in-out property <int> unread-count: 0;
    in-out property <string> status-text: "Ready";
    in-out property <string> refresh-label: "No refresh action yet";
    in-out property <string> runtime-summary: "Runtime not connected";
    in-out property <string> save-hint: "No save activity yet";
    in-out property <string> connection-label: "Unknown";
    in-out property <string> connection-tone: "offline";
    in-out property <string> stats-primary: "0 enabled group(s)";
    in-out property <string> stats-secondary: "0 section(s)";
    in-out property <string> stats-tertiary: "Tick 0 @ 0s poll";
    in-out property <string> stats-quaternary: "Updated n/a";
    in-out property <string> edge-width-label: "120 px";
    in-out property <[SignalRowData]> signal-rows: [];
    in-out property <bool> main-visible: true;
    in-out property <bool> widget-visible: true;
    in-out property <bool> pin-enabled: true;
    in-out property <bool> edge-mode: false;
    in-out property <bool> notifications-enabled: true;
    in-out property <bool> sound-enabled: true;
    in-out property <bool> more-open: false;

    callback toggle-always-on-top();
    callback toggle-edge-mode();
    callback adjust-edge-width(int);
    callback toggle-notifications();
    callback toggle-sound();
    callback toggle-widget();
    callback refresh-data();
    callback hide-main();
    callback save-config();
    callback quit-app();
    callback activate-signal(int);

    VerticalBox {
        padding: 2px;
        spacing: 2px;

        Rectangle {
            height: 30px;
            border-width: 1px;
            border-color: #c8c8c8;
            background: #efefef;

            PlainCheckBox {
                x: 6px;
                y: 5px;
                width: 40px;
                text: "置顶";
                checked <=> root.pin-enabled;
                toggled => {
                    root.toggle-always-on-top();
                }
            }

            PlainCheckBox {
                x: 52px;
                y: 5px;
                width: 72px;
                text: "贴边模式";
                checked <=> root.edge-mode;
                toggled => {
                    root.toggle-edge-mode();
                }
            }

            PlainCheckBox {
                x: 130px;
                y: 5px;
                width: 40px;
                text: "通知";
                checked <=> root.notifications-enabled;
                toggled => {
                    root.toggle-notifications();
                }
            }

            PlainCheckBox {
                x: 176px;
                y: 5px;
                width: 40px;
                text: "声音";
                checked <=> root.sound-enabled;
                toggled => {
                    root.toggle-sound();
                }
            }

            MoreButton {
                x: parent.width - self.width - 6px;
                y: 5px;
                text: root.more-open ? "收起" : "更多";
                clicked => {
                    root.more-open = !root.more-open;
                }
            }
        }

        if root.more-open : Rectangle {
            height: 54px;
            border-width: 1px;
            border-color: #c8c8c8;
            background: #f8f8f8;

            VerticalLayout {
                padding-left: 6px;
                padding-right: 6px;
                padding-top: 2px;
                padding-bottom: 2px;
                spacing: 2px;

                HorizontalBox {
                    spacing: 6px;

                    PlainButton {
                        text: "刷新";
                        clicked => {
                            root.more-open = false;
                            root.refresh-data();
                        }
                    }

                    PlainButton {
                        text: root.widget-visible ? "隐藏挂件" : "显示挂件";
                        clicked => {
                            root.more-open = false;
                            root.toggle-widget();
                        }
                    }

                    PlainButton {
                        text: "收起主窗";
                        clicked => {
                            root.more-open = false;
                            root.hide-main();
                        }
                    }

                    PlainButton {
                        text: "保存";
                        clicked => {
                            root.more-open = false;
                            root.save-config();
                        }
                    }

                    PlainButton {
                        text: "退出";
                        clicked => {
                            root.more-open = false;
                            root.quit-app();
                        }
                    }
                }

                HorizontalBox {
                    spacing: 6px;

                    Text {
                        text: "贴边宽度 " + root.edge-width-label;
                        color: #404040;
                        font-size: 11px;
                        vertical-alignment: center;
                    }

                    PlainButton {
                        text: "-";
                        clicked => {
                            root.adjust-edge-width(-20);
                        }
                    }

                    PlainButton {
                        text: "+";
                        clicked => {
                            root.adjust-edge-width(20);
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 28px;
            border-width: 1px;
            border-color: #c8c8c8;
            background: #f8f8f8;

            Text {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                text: root.unread-count + " | " + root.stats-quaternary + " | " + root.connection-label + " | " + root.status-text;
                color: #404040;
                font-size: 12px;
                overflow: elide;
            }
        }

        Rectangle {
            border-width: 1px;
            border-color: #c8c8c8;
            background: #ffffff;

            VerticalLayout {
                padding-left: 2px;
                padding-right: 2px;
                padding-top: 2px;
                padding-bottom: 2px;
                spacing: 2px;

                Rectangle {
                    height: 24px;
                    background: #f0f0f0;
                    border-width: 1px;
                    border-color: #d8d8d8;

                    Text {
                        x: 6px;
                        y: 5px;
                        width: parent.width - 12px;
                        text: "分组  " + root.stats-primary + "  " + root.stats-secondary + "  " + root.stats-tertiary;
                        color: #404040;
                        font-size: 12px;
                        overflow: elide;
                    }
                }

                ListView {
                    height: 610px;

                    for signal-row[index] in root.signal-rows : Rectangle {
                        height: signal-row.is_header ? 40px : 26px;
                        background: signal-row.is_header ? #f7f7f7 : #ffffff;
                        border-width: 1px;
                        border-color: #e0e0e0;

                        TouchArea {
                            clicked => {
                                if (!signal-row.pending && signal-row.unread &&
                                        ((signal-row.is_header && signal-row.unread_count > 0) ||
                                        !signal-row.is_header)) {
                                    root.activate-signal(index);
                                }
                            }
                        }

                        Text {
                            x: 6px;
                            y: signal-row.is_header ? 4px : 4px;
                            width: signal-row.is_header ? parent.width - 62px : 48px;
                            text: signal-row.title;
                            color: #202020;
                            font-size: signal-row.is_header ? 15px : 12px;
                            font-weight: signal-row.is_header ? 600 : (signal-row.unread ? 600 : 400);
                            overflow: elide;
                        }

                        Text {
                            x: signal-row.is_header ? 6px : 60px;
                            y: signal-row.is_header ? 22px : 4px;
                            width: signal-row.is_header ? parent.width - 72px : parent.width - 120px;
                            text: signal-row.meta;
                            color: signal-row.unread ? #404040 : #707070;
                            font-size: signal-row.is_header ? 11px : 10px;
                            overflow: elide;
                        }

                        Text {
                            x: parent.width - 48px;
                            y: signal-row.is_header ? 10px : 4px;
                            width: 42px;
                            text: signal-row.is_header
                                ? (signal-row.pending ? "..." : signal-row.unread_count)
                                : (signal-row.pending ? "..." : (signal-row.unread ? "新" : ""));
                            color: signal-row.unread ? #202020 : #808080;
                            font-size: 11px;
                            font-weight: 600;
                            horizontal-alignment: right;
                        }
                    }
                }
            }
        }
    }
}

export component WidgetWindow inherits Window {
    title: "Signal Desk Widget";
    preferred-width: 96px;
    preferred-height: 96px;
    min-width: 96px;
    min-height: 96px;
    max-width: 96px;
    max-height: 96px;
    always-on-top: true;
    no-frame: true;
    background: transparent;

    in-out property <int> unread-count: 0;
    in-out property <string> status-text: "Ready";
    in-out property <bool> widget-visible: true;
    in-out property <bool> drag-primed: false;
    in-out property <bool> drag-started: false;

    callback open-main();
    callback refresh-data();
    callback start-widget-drag();
    callback show-widget-menu();
    callback hover-started();
    callback hover-ended();

    TouchArea {
        mouse-cursor: grab;

        changed has-hover => {
            if self.has-hover {
                root.hover-started();
            } else {
                root.hover-ended();
            }
        }

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                root.drag-primed = true;
                root.drag-started = false;
            } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                root.drag-primed = false;
            } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                root.drag-primed = false;
                root.drag-started = false;
                root.show-widget-menu();
            } else if (event.kind == PointerEventKind.cancel) {
                root.drag-primed = false;
                root.drag-started = false;
            }
        }

        moved => {
            if (root.drag-primed && !root.drag-started &&
                    (Math.abs(self.mouse_x - self.pressed_x) > 3px ||
                    Math.abs(self.mouse_y - self.pressed_y) > 3px)) {
                root.drag-started = true;
                root.start-widget-drag();
            }
        }

        clicked => {
            if (!root.drag-started) {
                root.open-main();
            }
            root.drag-primed = false;
            root.drag-started = false;
        }

        double-clicked => {
            if (!root.drag-started) {
                root.refresh-data();
            }
            root.drag-primed = false;
            root.drag-started = false;
        }
    }

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 48px;
        background: root.widget-visible ? #2563eb : #475569;

        VerticalLayout {
            padding: 10px;
            spacing: 2px;
            alignment: center;

            Text {
                text: root.unread-count;
                color: #eff6ff;
                font-size: 34px;
                font-weight: 700;
                horizontal-alignment: center;
            }

            Text {
                text: "Signal";
                color: #dbeafe;
                font-size: 12px;
                horizontal-alignment: center;
            }
        }
    }
}
