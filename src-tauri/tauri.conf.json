{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Signal Desk",
  "version": "0.1.0",
  "identifier": "com.tauri.signaldesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Signal Desk Console",
        "width": 560,
        "height": 760,
        "minWidth": 420,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
